<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MITSURI APIS</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Poppins',sans-serif;}

body{
  background:url('<%= (user.wallpaper && user.wallpaper.trim() !== "") 
    ? user.wallpaper 
    : "https://i.postimg.cc/DZBZgy1f/b72a5dc0dba417c71f8e6a135c2dd001.jpg" %>') no-repeat center center fixed;
  background-size:cover;
  color:#fff;
  overflow-x:hidden;
}


/* overlay bonito */
body::before{
  content:"";
  position:fixed;
  width:100%;height:100%;
  background:linear-gradient(135deg, rgba(255,105,180,0.3), rgba(144,238,144,0.2));
  backdrop-filter:blur(6px);
  z-index:-1;
}

/* HEADER */
.header{
  height:60px;
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:0 20px;
  background:rgba(0,0,0,0.4);
  backdrop-filter:blur(10px);
  position:relative;
  z-index:1000;
}

/* botão */
.menu-btn{
  font-size:26px;
  cursor:pointer;
  transition:0.2s;
}
.menu-btn:hover{
  transform:scale(1.2);
}

/* perfil */
.profile{
  display:flex;
  align-items:center;
  gap:10px;
}
.profile img{
  width:40px;height:40px;
  border-radius:50%;
  border:2px solid #ff9ed6;
  box-shadow:0 0 10px #ff9ed6;
}

/* SIDEBAR */
.sidebar{
  position:fixed;
  top:0;
  left:-260px;
  width:260px;
  height:100%;
  background:rgba(0,0,0,0.8);
  backdrop-filter:blur(15px);
  padding:20px;
  transition:0.4s ease;
  z-index:2000; /* 🔥 agora fica na frente */
}

.sidebar.active{
  left:0;
}

.sidebar h2{
  color:#ff9ed6;
  margin-bottom:20px;
}

.sidebar a{
  display:block;
  padding:12px;
  margin:8px 0;
  text-decoration:none;
  color:#fff;
  border-radius:10px;
  transition:0.3s;
}

.sidebar a:hover{
  background:#ff9ed6;
  color:#000;
  box-shadow:0 0 10px #ff9ed6;
}

/* overlay quando abre */
.overlay{
  position:fixed;
  top:0;
  left:0;
  width:100%;
  height:100%;
  background:rgba(0,0,0,0.5);
  opacity:0;
  visibility:hidden;
  transition:0.3s;
  z-index:1500;
}

.overlay.active{
  opacity:1;
  visibility:visible;
}

/* MAIN */
.main{
  padding:20px;
  animation:fadeIn 0.6s ease;
}

@keyframes fadeIn{
  from{opacity:0;transform:translateY(10px);}
  to{opacity:1;transform:translateY(0);}
}

/* CARDS */
.cards{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
  gap:15px;
  margin-top:20px;
}

.card{
  background:rgba(255,255,255,0.08);
  padding:20px;
  border-radius:15px;
  backdrop-filter:blur(10px);
  transition:0.3s;
}

.card:hover{
  transform:translateY(-5px) scale(1.02);
  box-shadow:0 0 20px rgba(255,105,180,0.5);
}

.card h2{
  color:#ff9ed6;
}

/* animação entrada cards */
.card{
  animation:slideUp 0.5s ease;
}

@keyframes slideUp{
  from{opacity:0;transform:translateY(20px);}
  to{opacity:1;transform:translateY(0);}
}
</style>
</head>

<body>

<!-- SIDEBAR -->
<div class="sidebar" id="sidebar">
  <h2>🌸 MITSURI API</h2>

  <a href="/apis">APIS</a>
  <a href="#">STATS</a>
  <a href="/myperfil">PROFILE</a>

</div>

<!-- overlay -->
<div class="overlay" id="overlay" onclick="toggleMenu()"></div>

<!-- HEADER -->
<div class="header">
  <span class="menu-btn" onclick="toggleMenu()">☰</span>

  <div class="profile">
    <img src="<%= user.ft %>">
    <span><%= user.username %></span>
  </div>
</div>

<!-- MAIN -->
<div class="main">

  <h1>🌸 Dashboard</h1>

  <div class="cards">
    <div class="card">
      <h2>120</h2>
      <p>Usuários</p>
    </div>
    
  <div class="card">
  <h2><%= user.key %></h2>
  <p>Chave / API Key</p>
</div>

    <div class="card">
  <h2><%= user.saldo %></h2>
  <p>Requests restantes</p>
</div>

    <div class="card">
      <h2>Online</h2>
      <p>Status API</p>
    </div>
  </div>

</div>

<script>
function toggleMenu(){
  document.getElementById("sidebar").classList.toggle("active");
  document.getElementById("overlay").classList.toggle("active");
}
</script>

</body>
</html>