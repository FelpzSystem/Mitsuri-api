<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Registrar - Mitsuri</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Poppins',sans-serif;}

body{
  background:url('https://i.postimg.cc/DZBZgy1f/b72a5dc0dba417c71f8e6a135c2dd001.jpg') no-repeat center center fixed;
  background-size:cover;
  height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  color:white;
}

/* overlay */
body::before{
  content:"";
  position:fixed;
  width:100%;height:100%;
  background:linear-gradient(135deg, rgba(255,105,180,0.3), rgba(144,238,144,0.2));
  backdrop-filter:blur(8px);
  z-index:-1;
}

/* BOX */
.box{
  width:320px;
  padding:30px;
  border-radius:20px;
  background:rgba(255,255,255,0.08);
  backdrop-filter:blur(15px);
  animation:fade 0.6s ease;
}

@keyframes fade{
  from{opacity:0;transform:translateY(20px);}
  to{opacity:1;transform:translateY(0);}
}

/* TITLE */
.box h1{
  text-align:center;
  margin-bottom:20px;
  color:#ff9ed6;
}

/* INPUT */
.input{
  margin-bottom:15px;
}

.input input{
  width:100%;
  padding:12px;
  border:none;
  border-radius:10px;
  outline:none;
}

/* BTN */
button{
  width:100%;
  padding:12px;
  border:none;
  border-radius:12px;
  background:linear-gradient(45deg,#ff9ed6,#90ee90);
  font-weight:bold;
  cursor:pointer;
  transition:0.3s;
}

button:hover{
  transform:scale(1.05);
  box-shadow:0 0 15px #ff9ed6;
}

/* LINK */
p{
  text-align:center;
  margin-top:10px;
}

a{
  color:#ff9ed6;
  text-decoration:none;
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const form = document.getElementById('register-form');

  form.addEventListener("submit", function (e) {
    const username = document.getElementById('username').value;
    const password = document.getElementById('password').value;

    if (username.includes(" ")) {
      alert("❌ Username não pode ter espaço");
      e.preventDefault();
    }

    if (password.length < 4) {
      alert("❌ Senha muito curta (mín 4)");
      e.preventDefault();
    }
  });
});
</script>

</head>

<body>

<div class="box">
  <h1>🌸 Registrar</h1>

  <form id="register-form" action="/register" method="post">

    <div class="input">
      <input type="text" placeholder="Usuário" id="username" name="username" required>
    </div>

    <div class="input">
      <input type="password" placeholder="Senha" id="password" name="password" required>
    </div>

    <div class="input">
      <input type="email" placeholder="E-mail" name="email" required>
    </div>

    <button type="submit">Criar Conta</button>

    <p>Já tem conta? <a href="/">Entrar</a></p>

  </form>
</div>

</body>
</html>