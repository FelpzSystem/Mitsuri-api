<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Carregando...</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Poppins',sans-serif;
}

body{
  height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  background:url('https://i.postimg.cc/DZBZgy1f/b72a5dc0dba417c71f8e6a135c2dd001.jpg') no-repeat center;
  background-size:cover;
  color:#fff;
  animation:fadeIn 0.6s ease;
}

/* overlay */
body::before{
  content:"";
  position:fixed;
  width:100%;
  height:100%;
  background:linear-gradient(135deg, rgba(255,105,180,0.25), rgba(144,238,144,0.15));
  backdrop-filter:blur(10px);
  z-index:-1;
}

/* card */
.card{
  background:rgba(255,255,255,0.07);
  backdrop-filter:blur(15px);
  padding:35px;
  border-radius:20px;
  text-align:center;
  box-shadow:0 0 40px rgba(0,0,0,0.6);
  width:280px;
  animation:pop 0.5s ease;
}

/* logo */
.logo{
  font-size:24px;
  font-weight:600;
  margin-bottom:15px;
  letter-spacing:1px;
}

/* spinner */
.spinner{
  width:65px;
  height:65px;
  border:4px solid rgba(255,255,255,0.15);
  border-top:4px solid #ff9ed6;
  border-radius:50%;
  margin:20px auto;
  animation:spin 0.8s linear infinite;
  box-shadow:0 0 15px rgba(255,158,214,0.5);
}

/* text */
.text{
  font-size:14px;
  opacity:0.85;
}

/* dots */
.dots::after{
  content:"";
  animation:dots 1.5s infinite;
}

/* animations */
@keyframes spin{
  100%{transform:rotate(360deg);}
}

@keyframes dots{
  0%{content:"";}
  33%{content:".";}
  66%{content:"..";}
  100%{content:"...";}
}

@keyframes fadeIn{
  from{opacity:0;}
  to{opacity:1;}
}

@keyframes pop{
  from{transform:scale(0.9); opacity:0;}
  to{transform:scale(1); opacity:1;}
}

/* saída suave */
.fade-out{
  animation:fadeOut 0.5s ease forwards;
}

@keyframes fadeOut{
  to{opacity:0;}
}
</style>
</head>

<body>

<div class="card" id="card">

  <div class="logo">MITSURI</div>

  <div class="spinner"></div>

  <div class="text">
    Carregando<span class="dots"></span>
  </div>

</div>

<script>
setTimeout(() => {
  document.body.classList.add('fade-out')
  setTimeout(() => {
    window.location.href = "/home"
  }, 400)
}, 2000)
</script>

</body>
</html>