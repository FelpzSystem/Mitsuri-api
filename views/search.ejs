<!DOCTYPE html>
<html lang="pt-br">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mitsuri - Search</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Poppins', sans-serif;
}

body {
    background: linear-gradient(135deg, #ffd6e8, #d9fff3);
    min-height: 100vh;
    color: #2b2b2b;
}

/* HEADER */
.header {
    position: fixed;
    top: 0;
    width: 100%;
    height: 60px;
    background: rgba(255,255,255,0.7);
    backdrop-filter: blur(10px);
    display: flex;
    align-items: center;
    padding: 0 20px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.1);
}

/* MENU */
.menu-container {
    position: fixed;
    top: 0;
    left: -260px;
    width: 250px;
    height: 100%;
    background: linear-gradient(180deg, #ffb6d5, #aef7df);
    padding: 20px;
    transition: 0.3s;
    box-shadow: 5px 0 20px rgba(0,0,0,0.2);
}

.menu-container.show-menu {
    left: 0;
}

.menu-toggle {
    font-size: 28px;
    cursor: pointer;
}

.close-button {
    font-size: 22px;
    cursor: pointer;
}

/* TITLE */
h2 {
    margin-top: 100px;
    text-align: center;
    color: #ff4fa3;
}

/* SEARCH */
form {
    text-align: center;
    margin-top: 20px;
}

input[type="text"] {
    width: 80%;
    padding: 12px;
    border-radius: 12px;
    border: none;
    outline: none;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
}

button {
    margin-top: 10px;
    padding: 10px 25px;
    border: none;
    border-radius: 12px;
    background: linear-gradient(90deg, #ff4fa3, #7fffd4);
    color: white;
    font-weight: bold;
    cursor: pointer;
    transition: 0.2s;
}

button:hover {
    transform: scale(1.05);
}

/* RESULTADOS */
.container {
    width: 90%;
    margin: 30px auto;
    padding: 20px;
    border-radius: 20px;
    background: rgba(255,255,255,0.7);
    backdrop-filter: blur(10px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.15);
}

ul {
    list-style: none;
}

li {
    background: #fff;
    padding: 15px;
    margin: 10px 0;
    border-radius: 15px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
}

/* BUTTONS */
.flex {
    display: flex;
    gap: 10px;
    margin-top: 10px;
}

.deletar {
    background: #ff4d6d;
}

.deletar:hover {
    background: #ff1f4b;
}

/* MENU CLOSE */
.menu-container h3 {
    margin-top: 20px;
}
</style>
</head>

<body>

<!-- MENU -->
<div class="menu-container" id="menu">
    <span class="close-button" onclick="toggleMenu()">✖</span>
    <h3>🌸 Menu Mitsuri</h3>
</div>

<!-- HEADER -->
<div class="header">
    <div class="menu-toggle" onclick="toggleMenu()">☰</div>
</div>

<!-- SEARCH -->
<h2>🔎 Resultado da Pesquisa</h2>

<form action="/search" method="GET">
    <input type="text" name="search" placeholder="Pesquisar usuário...">
    <br>
    <button type="submit">Pesquisar</button>
</form>

<!-- RESULTADOS -->
<div class="container">

<h3 style="text-align:center;">
    Resultados para: <%= searchTerm %>
</h3>

<br>

<% if (searchResults && searchResults.length > 0) { %>

<ul>

<% searchResults.forEach(result => { %>

    <li>
        👤 <%= result.username %>

        <div class="flex">
            <a href="/deletar/<%= result.username %>">
                <button class="deletar">Deletar</button>
            </a>

            <a href="/editar/<%= result.username %>">
                <button>Editar</button>
            </a>
        </div>
    </li>

<% }); %>

</ul>

<% } else { %>

<p style="text-align:center;">Nenhum resultado encontrado 🌸</p>

<% } %>

</div>

<script>
function toggleMenu() {
    document.getElementById('menu').classList.toggle('show-menu');
}
</script>

</body>
</html>